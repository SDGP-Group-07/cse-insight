# App Configuration
VITE_APP_NAME=CSE Insight
VITE_APP_VERSION=1.0.0
VITE_API_URL=http://localhost:5000/api

# Authentication
VITE_JWT_SECRET=your-super-secret-jwt-key-change-in-production
VITE_JWT_EXPIRY=7d

# API Keys (if needed)
VITE_CSE_API_KEY=your-cse-api-key
VITE_OPENAI_API_KEY=your-openai-key
VITE_CLAUDE_API_KEY=your-claude-key

# Feature Flags
VITE_ENABLE_CHAT=true
VITE_ENABLE_RAG=true
VITE_ENABLE_PREDICTIONS=true

# External Services
VITE_CSE_WEBSITE_URL=https://www.cse.lk
VITE_NEWS_API_URL=https://api.newsapi.org/v2
